# Copy this file to start_gui.env and edit values.
# start_gui.sh will auto-load this file.

API_FOOTBALL_KEY=your_api_football_key
MQTT_HOST=172.20.10.13
MQTT_PORT=1883
HIDE_PANEL=0
PANEL_GUARD=0
QT_ACCESSIBILITY=1
QT_LINUX_ACCESSIBILITY_ALWAYS_ON=1

# Optional overrides:
# FIXTURE_TOPIC=stadium/config/fixture_id
# WAIT_SEC=30
# APP_DIR=/home/dev/sigma3/touchscreen-module
# VENV_DIR=/home/dev/sigma3/touchscreen-module/.venv
# PANEL_GUARD_SLEEP_SEC=1
# XDG_RUNTIME_DIR=/run/user/1000
# DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
